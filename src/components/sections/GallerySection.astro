---
import ScreenshotMockup from './gallery/ScreenshotMockup.astro';

const tabs = [
  { label: 'Reservas', subtitle: 'Formulario de reserva', desc: 'Tus clientes reservan en segundos desde cualquier dispositivo.', img: '/images/trimbook/trimbook-cliente-formulario-reserva.png', alt: 'Formulario de reserva para clientes', url: 'trimbook.app/reservar' },
  { label: 'Calendario', subtitle: 'Calendario dinámico', desc: 'Vista completa de tu agenda en tiempo real. Arrastra, edita y gestiona.', img: '/images/trimbook/trimbook-admin-calendario.png', alt: 'Calendario de administración', url: 'trimbook.app/agenda' },
  { label: 'Estadísticas', subtitle: 'Panel de métricas', desc: 'Ingresos, clientes y tendencias. Todo lo que necesitas para crecer.', img: '/images/trimbook/trimbook-admin-dashboard.png', alt: 'Dashboard de estadísticas', url: 'trimbook.app/dashboard' },
  { label: 'Agente IA', subtitle: 'Reservas por WhatsApp', desc: 'Tu asistente IA recibe y confirma citas 24/7 sin que muevas un dedo.', img: '/images/trimbook/trimbook-reservas-cliente.png', alt: 'Reservas de cliente vía WhatsApp', url: 'wa.trimbook.app' },
];
---

<section id="funciones" class="gallery-section reveal" data-gallery-root>
  <div class="gallery-inner">
    <div class="gallery-tabs" role="tablist" aria-label="Funcionalidades">
      <p class="gallery-eyebrow">Funcionalidades</p>
      {tabs.map((t, i) => (
        <button
          type="button"
          class={`gallery-tab${i === 0 ? ' gallery-tab--active' : ''}`}
          role="tab"
          data-gallery-tab={i}
          data-subtitle={t.subtitle}
          data-desc={t.desc}
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          <div class="gallery-tab-num">{String(i + 1).padStart(2, '0')}</div>
          <div>
            <div class="gallery-tab-label">{t.label}</div>
            <div class="gallery-tab-sub">{t.subtitle}</div>
          </div>
        </button>
      ))}
    </div>

    <div class="gallery-preview">
      {tabs.map((t, i) => (
        <div
          class={`gallery-mockup${i === 0 ? ' gallery-mockup--in' : ''}`}
          data-gallery-panel={i}
          role="tabpanel"
          {...(i !== 0 ? { hidden: true } : {})}
        >
          <ScreenshotMockup src={t.img} alt={t.alt} url={t.url} />
        </div>
      ))}
      <div class="gallery-desc-bar">
        <span class="gallery-desc-label" data-gallery-desc-label>{tabs[0].subtitle}</span>
        <span class="gallery-desc-text" data-gallery-desc-text>{tabs[0].desc}</span>
      </div>
    </div>
  </div>
</section>

<script>
  import { initGalleryTabs } from '../../scripts/gallery-tabs';

  const roots = document.querySelectorAll<HTMLElement>('[data-gallery-root]');
  roots.forEach((root) => initGalleryTabs(root));
</script>

<style is:global>
  @import '../../styles/sections/gallery.css';
</style>
