---
const productoLinks = ['Funcionalidades', 'Precios', 'Integraciones', 'Agente IA', 'Changelog'];
const empresaLinks = ['Sobre nosotros', 'Blog', 'Contacto', 'Únete al equipo', 'Afiliados'];
const legalLinks = [
  { label: 'Aviso Legal', href: '/aviso-legal' },
  { label: 'Política de Privacidad', href: '/politica-de-privacidad' },
  { label: 'Política de Cookies', href: '/politica-de-cookies' },
  { label: 'Términos y Condiciones', href: '/terminos-y-condiciones' },
  { label: 'Protección de Datos (RGPD)', href: '/proteccion-de-datos' },
  { label: 'Gestionar Cookies', href: '/configurar-cookies' },
];
---

<footer class="footer reveal">
  <div class="footer-top">
    <div class="footer-brand">
      <div class="footer-logo">Trimbook<sup>®</sup></div>
      <p class="footer-tagline">Software de reservas para barberías modernas. Gestiona, crece y fideliza — sin complicaciones.</p>
      <p class="footer-newsletter-label">Suscríbete a las novedades:</p>
      <form class="footer-form" data-newsletter-form>
        <input type="email" placeholder="tu@email.com" class="footer-input" aria-label="Email para newsletter" />
        <button type="submit" class="footer-form-btn" aria-label="Suscribirse">→</button>
      </form>
    </div>

    <div class="footer-col">
      <p class="footer-col-title">Producto</p>
      {productoLinks.map((link) => (
        <a href="#" class="footer-link">{link}</a>
      ))}
    </div>

    <div class="footer-col">
      <p class="footer-col-title">Empresa</p>
      {empresaLinks.map((link) => (
        <a href={link === 'Contacto' ? '#contacto' : '#'} class="footer-link">{link}</a>
      ))}
    </div>

    <div class="footer-col">
      <p class="footer-col-title">Legal</p>
      {legalLinks.map((link) => (
        <a href={link.href} class="footer-link">{link.label}</a>
      ))}
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-left">
      <span>© 2025 Trimbook Technologies S.L.</span>
      <span class="footer-sep">·</span>
      <a href="mailto:hola@trimbook.app" class="footer-bottom-link">hola@trimbook.app</a>
      <span class="footer-sep">·</span>
      <span>B-12345678 · Madrid, España</span>
    </div>
    <div class="footer-socials">
      <a href="#" class="footer-social" aria-label="Instagram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"></circle>
        </svg>
      </a>
      <a href="#" class="footer-social" aria-label="LinkedIn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="3"></rect><path d="M7 10v7M7 7v.01M12 17v-4a2 2 0 014 0v4M12 10v7"></path>
        </svg>
      </a>
      <a href="#" class="footer-social" aria-label="WhatsApp">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"></path>
        </svg>
      </a>
    </div>
  </div>

  <div class="footer-wordmark" aria-hidden="true">Trimbook</div>
</footer>

<script>
  document.querySelectorAll('[data-newsletter-form]').forEach((form) => {
    form.addEventListener('submit', (e) => e.preventDefault());
  });
</script>

<style is:global>
  @import '../../styles/sections/footer.css';
</style>
