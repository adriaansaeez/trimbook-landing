---
const features = [
  { text: 'Disponibilidad en tiempo real', sub: '— consulta tu calendario al instante' },
  { text: 'Reservas automáticas', sub: '— confirma citas sin intervención humana' },
  { text: 'Entrenado para tu negocio', sub: '— conoce tus servicios, precios y horarios' },
];
---

<section class="trimbi-section reveal">
  <div class="trimbi-inner">
    <div class="trimbi-left">
      <div class="trimbi-eyebrow">
        <span class="trimbi-eyebrow-dot"></span>
        <span>Nuevo · Agente IA</span>
      </div>
      <h2 class="trimbi-headline">
        Conoce a <span class="trimbi-headline-accent">Trimbi.</span><br />
        Tu recepcionista<br />
        por WhatsApp.
      </h2>
      <p class="trimbi-desc">
        Trimbi atiende a tus clientes desde WhatsApp 24/7. Consulta huecos, gestiona cancelaciones y confirma reservas sin que tengas que tocar el móvil.
      </p>
      <div class="trimbi-features">
        {features.map((f) => (
          <div class="trimbi-feature">
            <div class="trimbi-feature-icon">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8l3 3 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
            <p class="trimbi-feature-text">
              {f.text} <span>{f.sub}</span>
            </p>
          </div>
        ))}
      </div>
      <div class="trimbi-cta-row">
        <button type="button" class="trimbi-cta">
          Activar Trimbi
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <a href="#funciones" class="trimbi-cta-secondary">Ver demo en vivo →</a>
      </div>
    </div>

    <div class="trimbi-phone-wrap" data-trimbi-chat>
      <div class="trimbi-phone">
        <div class="trimbi-phone-notch"></div>
        <div class="trimbi-phone-screen">
          <div class="trimbi-wa-status">
            <span>9:41</span>
            <div class="trimbi-wa-status-icons">
              <svg width="14" height="10" viewBox="0 0 16 10" fill="currentColor" aria-hidden="true"><path d="M1 4l1-1c3.5-3 9-3 12.5 0l1 1-1.4 1.4-1-1c-2.5-2.2-6.6-2.2-9.2 0l-1 1L1 4zm3 3l1-1c1.7-1.5 4.4-1.5 6.1 0l1 1L10.7 8.4l-1-1c-.9-.7-2.4-.7-3.3 0l-1 1L4 7z"></path></svg>
            </div>
          </div>
          <div class="trimbi-wa-header">
            <div class="trimbi-wa-avatar">T</div>
            <div class="trimbi-wa-info">
              <div class="trimbi-wa-name">
                Trimbi
                <span class="trimbi-wa-verified">✓</span>
              </div>
              <div class="trimbi-wa-presence">en línea · responde al instante</div>
            </div>
          </div>
          <div class="trimbi-wa-chat">
            <div class="trimbi-wa-date">HOY</div>
            <div data-trimbi-messages></div>
            <div class="trimbi-wa-typing" data-trimbi-typing hidden>
              <span></span><span></span><span></span>
            </div>
          </div>
          <div class="trimbi-wa-input">
            <div class="trimbi-wa-input-field">Escribe un mensaje…</div>
            <div class="trimbi-wa-input-btn" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.91-3c-.49 0-.9.36-.98.85C16.52 14.2 14.47 16 12 16s-4.52-1.8-4.93-4.15c-.08-.49-.49-.85-.98-.85-.61 0-1.09.54-1 1.14.49 3 2.89 5.35 5.91 5.78V20c0 .55.45 1 1 1s1-.45 1-1v-2.08c3.02-.43 5.42-2.78 5.91-5.78.1-.6-.39-1.14-1-1.14z"></path></svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initTrimbiChat } from '../../scripts/trimbi-chat';

  const roots = document.querySelectorAll<HTMLElement>('[data-trimbi-chat]');
  const cleanups: Array<(() => void) | undefined> = [];
  roots.forEach((root) => cleanups.push(initTrimbiChat(root)));

  document.addEventListener('astro:before-swap', () => {
    cleanups.forEach((c) => c?.());
  });
</script>

<style is:global>
  @import '../../styles/sections/trimbi.css';
</style>
