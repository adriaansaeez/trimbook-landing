import HeroNav from './HeroNav.astro';
import Hero from './Hero.astro';
---

<div id="inicio" class="hero-section-wrap">
  <VideoBackground />
  <HeroNav />
  <Hero />
</div>

<style>
  .hero-section-wrap {
    position: relative;
    min-height: 100vh;
    width: 100%;
    background: transparent;
  }
</style>
