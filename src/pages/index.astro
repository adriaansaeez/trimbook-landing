---
import Layout from '../layouts/Layout.astro';
import ScrollEffects from '../components/ScrollEffects.astro';
import HeroSection from '../components/hero/HeroSection.astro';
import HeroNav from '../components/hero/HeroNav.astro';
import TrimbiSection from '../components/sections/TrimbiSection.astro';
import GallerySection from '../components/sections/GallerySection.astro';
import BentoSection from '../components/sections/BentoSection.astro';
import StatsSection from '../components/sections/StatsSection.astro';
import PricingSection from '../components/sections/PricingSection.astro';
import LeadSection from '../components/sections/LeadSection.astro';
import Footer from '../components/sections/Footer.astro';
---

<Layout>
  <ScrollEffects />
  <HeroNav variant="sticky" />
  <main>
    <HeroSection />
    <TrimbiSection />
    <GallerySection />
    <BentoSection />
    <StatsSection />
    <PricingSection />
    <LeadSection />
  </main>
  <Footer />
</Layout>
